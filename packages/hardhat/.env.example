# Template for Hardhat environment variables.

# To use this template, copy this file, rename it .env, and fill in the values.

# If not set, we provide default values (check `hardhat.config.ts`) so developers can start prototyping out of the box,
# but we recommend getting your own API Keys for Production Apps.

# To access the values stored in this .env file you can use: process.env.VARIABLENAME
ALCHEMY_API_KEY=
ETHERSCAN_MAINNET_API_KEY=

# Don't fill this value manually, run yarn generate to generate a new account or yarn account:import to import an existing PK.
DEPLOYER_PRIVATE_KEY_ENCRYPTED=

# --- Running alongside another project (agent-friendly multi-chain) ---
# When another hardhat node is already bound to 8545 (another agent, another worktree),
# run this one on a different port and tell the tooling about it.
#
# Terminal 1:  yarn fork --port 8546               # hardhat node listens on 8546
# Terminal 2:  LOCALHOST_RPC_URL=http://127.0.0.1:8546 yarn deploy
#              (or export once in your shell; simulate/seed scripts pick it up too)
#
# Unset / leave blank = default http://127.0.0.1:8545.
LOCALHOST_RPC_URL=

# --- Sepolia forking (required for `yarn fork` / `yarn preview`) ---
# The hardhat network forks Sepolia at a pinned block so contract addresses, EAS schema
# UIDs, and the committed `deployedContracts.ts` are byte-identical across every
# environment (local, devnet VPS, GitHub Pages client). See ADR-0037.
#
# `yarn preview` sets MAINNET_FORKING_ENABLED=true automatically. Set it here if you run
# `yarn fork` directly.
MAINNET_FORKING_ENABLED=true
#
# Pin block override. Leave blank to use the default in hardhat.config.ts. Bumping this
# requires regenerating deployedContracts.ts and committing the result — that's the
# coordination unit with the devnet.
FORK_BLOCK=
