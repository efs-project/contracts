# Template for NextJS environment variables.

# For local development, copy this file, rename it to .env.local, and fill in the values.
# When deploying live, you'll need to store the vars in Vercel/System config.

# If not set, we provide default values (check `scaffold.config.ts`) so developers can start prototyping out of the box,
# but we recommend getting your own API Keys for Production Apps.

# To access the values stored in this env file you can use: process.env.VARIABLENAME
# You'll need to prefix the variables names with NEXT_PUBLIC_ if you want to access them on the client side.
# More info: https://nextjs.org/docs/pages/building-your-application/configuring/environment-variables
NEXT_PUBLIC_ALCHEMY_API_KEY=
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=

# --- Running alongside another project (agent-friendly multi-chain) ---
# Point the frontend at a non-default hardhat node RPC when running multiple
# agents/worktrees in parallel. See packages/hardhat/.env.example for the server side.
#
# This single var drives BOTH the public client (reads) and the burner wallet (writes):
# `scaffold.config.ts` patches the hardhat chain's rpcUrls so every transport — wagmi's
# fallback() and burner-connector — lands on the same node.
#
# Example (hardhat on 8546, this dev server on 3001):
#   NEXT_PUBLIC_HARDHAT_RPC_URL=http://127.0.0.1:8546
#   yarn start -p 3001
#
# Unset / leave blank = viem's default for chain `hardhat` (http://127.0.0.1:8545).
NEXT_PUBLIC_HARDHAT_RPC_URL=

# --- Network selection (hardhat fork vs live Sepolia) ---
# The debug UI ships BOTH the local hardhat Sepolia-fork (31337) and live Sepolia
# (11155111). Flip between them at runtime via the NetworkSwitcher in the header.
#
# This var only sets the DEFAULT network — the chain reads run on before a wallet
# connects, and the one the store starts on. Accepts: hardhat | local | 31337 |
# sepolia | 11155111. Blank/whitespace counts as unset.
#
# Unset → default by BUILD TYPE, so each audience just works with zero config:
#   * `next dev`   (development)     → hardhat — paired with your local `yarn preview` fork.
#   * `next build` static SPA (prod) → sepolia — a deployed SPA has no local node.
# Set this explicitly to override either way. IMPORTANT: a production export that must
# target a hardhat fork instead (e.g. the devnet VPS via NEXT_PUBLIC_HARDHAT_RPC_URL above)
# MUST set NEXT_PUBLIC_TARGET_CHAIN=hardhat — otherwise the prod build defaults to Sepolia.
NEXT_PUBLIC_TARGET_CHAIN=

# Override live Sepolia's RPC (mirrors NEXT_PUBLIC_HARDHAT_RPC_URL for the fork).
# Unset = viem's default public Sepolia RPC, with wagmiConfig's Alchemy endpoint
# as a fallback (uses NEXT_PUBLIC_ALCHEMY_API_KEY, or the bundled default key).
#
# STRONGLY RECOMMENDED for live Sepolia. The explorer issues a high volume of
# reads (one block-watcher per useScaffoldReadContract; ~45 in the explorer tree),
# each cross-origin call to a public RPC also pays a CORS preflight. Against the
# bundled public endpoint — especially while a local hardhat fork is also being
# polled — those reads starve under the browser's ~6-connections-per-host cap and
# the explorer can hang on "Loading System…". A dedicated provider (Alchemy/Infura
# eth-sepolia, or a same-origin reverse-proxy) resolves it. Verified: the explorer
# loads cleanly on live Sepolia with a dedicated RPC. Setting your own
# NEXT_PUBLIC_ALCHEMY_API_KEY also helps (it flips wagmi to prefer Alchemy).
NEXT_PUBLIC_SEPOLIA_RPC_URL=

# --- Devnet / VPS deployment (same-origin reverse-proxy config) ---
# When this app is served from a public host that reverse-proxies its own chain +
# IPFS + Arweave daemons (e.g. the EFS devnet at https://178.104.79.94.nip.io),
# point every external URL at same-origin paths so browsers don't cross origins.
#
# Examples for the devnet (Caddy auto-upgrades HTTP→WS on /rpc, so leave WS URL
# unset and let the auto-derive in useFetchBlocks.ts swap https→wss):
#   NEXT_PUBLIC_SITE_URL=https://178.104.79.94.nip.io
#   NEXT_PUBLIC_HARDHAT_RPC_URL=https://178.104.79.94.nip.io/rpc
#   NEXT_PUBLIC_IPFS_GATEWAY=https://178.104.79.94.nip.io/ipfs/
#   NEXT_PUBLIC_ARWEAVE_GATEWAY=https://178.104.79.94.nip.io/arweave/
#   # NEXT_PUBLIC_HARDHAT_WS_URL=  (unset — derived as wss://...nip.io/rpc)
#
# Leaving them unset keeps local-dev behavior: localhost RPC, dweb.link / arweave.net
# gateways. Trailing slashes on the gateway vars matter — they are concatenated
# directly with the CID / tx id.

# Absolute site URL for Next.js `metadataBase` (og:image, twitter:image, canonical
# URLs). Without this, the VPS build leaks `http://localhost:3000` into link previews.
# Vercel auto-provides VERCEL_PROJECT_PRODUCTION_URL; other hosts must set this.
NEXT_PUBLIC_SITE_URL=

# WebSocket RPC for the /blockexplorer debug page. Auto-derived from
# NEXT_PUBLIC_HARDHAT_RPC_URL (http(s) → ws(s)) when absolute — unset is usually
# correct. Set explicitly ONLY when your reverse proxy exposes WebSocket at a
# DIFFERENT path than HTTP RPC. Most modern proxies (Caddy, nginx w/ Upgrade
# header) handle the HTTP→WS upgrade transparently on a single path, so the
# auto-derived URL is what you want.
NEXT_PUBLIC_HARDHAT_WS_URL=

# Base URL for resolving `ipfs://<cid>` to a fetchable HTTP(S) URL. Trailing `/`
# required. Default: https://dweb.link/ipfs/ (public gateway — fine for local dev).
NEXT_PUBLIC_IPFS_GATEWAY=

# Base URL for resolving `ar://<txid>` to a fetchable HTTP(S) URL. Trailing `/`
# required. Default: https://arweave.net/ (public gateway — fine for local dev).
NEXT_PUBLIC_ARWEAVE_GATEWAY=

# Top-of-page banner text for non-mainnet builds. Empty / unset = no banner.
# Set on devnet builds so visitors see "this is not mainnet, data is not real":
#   NEXT_PUBLIC_DEVNET_BANNER="DEVNET — resets weekly. Do not store real data."
# Dismissible per-session (sessionStorage); reappears on new tabs / reloads.
NEXT_PUBLIC_DEVNET_BANNER=

# Build-time identity, surfaced in the NetworkChip (bottom-right) for bug
# reports and sanity-checking that the devnet you're hitting matches the
# frontend that's loaded.
#
# Both are AUTO-POPULATED by next.config.js at build time:
#   - NEXT_PUBLIC_GIT_SHA: `git rev-parse HEAD` at build time (empty if git unavailable)
#   - NEXT_PUBLIC_FORK_BLOCK: mirrors FORK_BLOCK (or defaults to 10691000 per ADR-0037)
# Override either only if you need a specific value (e.g. CI that builds from
# a tarball has no .git dir; set NEXT_PUBLIC_GIT_SHA=<sha> explicitly).
NEXT_PUBLIC_GIT_SHA=
NEXT_PUBLIC_FORK_BLOCK=

