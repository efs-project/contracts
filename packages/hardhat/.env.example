# Hardhat environment variables. Copy to .env and fill in.
# Blank values fall back to defaults in hardhat.config.ts (fine for prototyping; use your own
# keys for real deploys). Config code should use the helpers in ./env (envOr,
# positiveIntEnvOr, boolEnv, oneOfEnvOr) so empty strings are treated as unset
# instead of becoming live config values.

# ── RPC endpoints ──
# Default provider key for all live networks + the Sepolia fork. Get your own — the shared
# default is rate-limited.
ALCHEMY_API_KEY=
# Override the LIVE `sepolia` network RPC, e.g. to use Infura instead of Alchemy:
#   https://sepolia.infura.io/v3/<key>.  Blank = Alchemy.
SEPOLIA_RPC_URL=
# Override the Sepolia *fork* RPC (must be archive-capable). Dodge demo-key 429s with e.g.
#   https://sepolia.drpc.org.  Blank = Alchemy.
SEPOLIA_FORK_RPC_URL=
# Point hardhat's `localhost` network at a non-default node (e.g. a second `yarn fork --port 8546`).
# Blank = http://127.0.0.1:8545
LOCALHOST_RPC_URL=

# ── Etherscan (verify only) ──
# Only for `hardhat verify` (publishing source). Optional — not needed to deploy.
ETHERSCAN_MAINNET_API_KEY=

# ── Deployer account ──
# Encrypted deployer key. Don't set by hand — run `yarn account:generate` or `yarn account:import`.
DEPLOYER_PRIVATE_KEY_ENCRYPTED=

# ── Live deploy: Sepolia / mainnet freeze (docs/DEPLOYMENT.md §4) ──
# The EFS.eth Safe that owns the frozen foundation. Required for `deploy:efs --via-safe` (and the
# EOA-path ownership transfer); hard-fails if unset/invalid. Checksummed — becomes the CreateX caller.
EFS_SAFE_ADDRESS=

# ── Local fork behavior (`yarn fork` / `yarn preview`) ──
# Fork Sepolia at a pinned block so addresses/UIDs/deployedContracts.ts are identical everywhere
# (ADR-0037). `yarn preview` sets this automatically.
MAINNET_FORKING_ENABLED=true
# Pin-block override. Blank = hardhat.config.ts default. Bumping requires regenerating + committing
# deployedContracts.ts.
FORK_BLOCK=
